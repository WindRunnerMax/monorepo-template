    "@workspace/utils": "workspace: *",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "nodemon": "3.0.1",
    "@rsbuild/core": "1.7.4",
    "webpack-node-externals": "^3.0.0"
  }
