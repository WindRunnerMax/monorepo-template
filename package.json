{
  "name": "@workspace/root",
  "version": "1.0.0",
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile",
    "lint:ts": "pnpm run --filter '*' lint:ts",
    "lint:es": "eslint --fix --ext .js,.jsx,.ts,.tsx --ignore-path .gitignore .",
    "lint:style": "stylelint \"**/*.{css,scss,sass}\" --fix --ignore-path .gitignore",
    "rm:modules": "pnpm --parallel -r exec rm -rf node_modules && rm -rf node_modules"
  },
  "keywords": [],
  "author": "Czy",
  "license": "MIT",
  "packageManager": "pnpm@8.11.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WindrunnerMax/ReactRspackTemplate"
  },
  "bugs": {
    "url": "https://github.com/WindrunnerMax/ReactRspackTemplate/issues"
  },
  "homepage": "https://github.com/WindrunnerMax/ReactRspackTemplate",
  "devDependencies": {
    "@types/node": "20.11.10",
    "@typescript-eslint/eslint-plugin": "8.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "concurrently": "9.2.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.25.3",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.27.0",
    "eslint-plugin-react-hooks": "4.3.0",
    "eslint-plugin-simple-import-sort": "10.0.0",
    "postcss": "8.5.3",
    "prettier": "3.3.3",
    "sass": "1.70.0",
    "stylelint": "14.7.1",
    "stylelint-config-sass-guidelines": "9.0.1",
    "stylelint-config-standard": "25.0.0",
    "tsx": "4.21.0",
    "typescript": "5.3.2"
  }
}
